# ============================================================
# Suka Brew AI Chatbot — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# Claude AI (required for chat recommendations)
# Get yours FREE at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App settings
PORT=3000
PUBLIC_URL=http://localhost:3000

# Voice: FREE — uses browser's built-in Web Speech API
# No extra API keys needed for voice input or output!

# For production deployment (Railway/Render):
# PUBLIC_URL=https://your-app-name.railway.app
